# ── SmartJob Agent – API Keys ──────────────────────────

# 1. ADZUNA API (Recomendada - 5,000 req/mes gratis)
#    Ve a https://developer.adzuna.com/
#    Crea una cuenta gratuita y obtén tus credenciales
ADZUNA_APP_ID=tu_app_id
ADZUNA_APP_KEY=tu_app_key

# 2. RapidAPI (Opcional - para LinkedIn Jobs y JSearch)
#    Ve a https://rapidapi.com/jaypat87/api/linkedin-jobs-search
#    Crea cuenta gratuita (500 requests/mes gratis)
#    Copia tu API key y pégala aquí
RAPIDAPI_KEY=tu_api_key_aqui

# Configuración del servidor
PORT=3333
